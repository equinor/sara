{
  "AppName": "sara-backend",
  "AzureAd": {
    "TenantId": "3aa4a235-b6e2-48d5-9195-7fcf05b459b0",
    "Instance": "https://login.microsoftonline.com"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.IdentityModel": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "https://*.equinor.com/"
  ],
  "Database": {
    "AllowedAuthMethods": [ "ConnectionString" ],
    "postgresConnectionString": "",
    "Server": "",
    "PostgresDatabase": "",
    "User": "",
    "Timeout": 30
  },
  "KeyVault": {
    "UseKeyVault": true
  },
  "ApiBaseRoute": "",
  "Frontend": {
    "Enabled": true
  },
  "Mqtt": {
    "Host": "localhost",
    "Port": 1883,
    "Username": "sara",
    "Topics": [
      "isar/+/inspection_result",
      "isar/+/inspection_value"
    ],
    "MaxRetryAttempts": 5,
    "ShouldFailOnMaxRetries": false,
    "AllowInsecureLocalConnections": false
  },
  "Analysis": {
    "Analyses": {
      "anonymize": { "Workflows": ["anonymizer"] },
      "fencilla": { "Workflows": ["anonymizer", "fencilla"] },
      "cloe": { "Workflows": ["anonymizer", "cloe"] },
      "thermal-reading": { "Workflows": ["anonymizer", "thermal-reading"] }
    },
    "Workflows": {
      "anonymizer": {
        "TriggerUrl": "http://trigger-anonymizer-source:8080/trigger-anonymizer",
        "OutputStorageAccount": "saradevstoreanon",
        "OutputBlobContainer": "",
        "OutputFileExtension": ".jpg"
      },
      "fencilla": {
        "TriggerUrl": "http://trigger-fencilla-source:8080/trigger-fencilla",
        "OutputStorageAccount": "saradevstorevis",
        "OutputBlobContainer": ""
      },
      "cloe": {
        "TriggerUrl": "http://trigger-cloe-source:8080/trigger-constant-level-oiler-estimator",
        "OutputStorageAccount": "saradevstorevis",
        "OutputBlobContainer": ""
      },
      "thermal-reading": {
        "TriggerUrl": "http://trigger-thermal-reading-source:8080/trigger-thermal-reading",
        "OutputStorageAccount": "saradevstorevis",
        "OutputBlobContainer": ""
      }
    },
    "DefaultAnalysisByFileExtension": {
      ".jpg": ["anonymize"],
      ".jpeg": ["anonymize"],
      ".png": ["anonymize"]
    },
    "AnalysisGroupTimeoutMinutes": 30
  },
  "SARATimeseriesBaseUrl": "http://sara-timeseries:8200",
  "Storage": {
    "ThermalReferenceStorageAccount": ""
  },
  "Email": {
    "Fencilla": {
      "Installations": {}
    }
  }
}
