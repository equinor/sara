{
  "AppName": "sara-backend",
  "AzureAd": {
    "TenantId": "3aa4a235-b6e2-48d5-9195-7fcf05b459b0",
    "Instance": "https://login.microsoftonline.com"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.IdentityModel": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "https://*.equinor.com/"
  ],
  "Database": {
    "AllowedAuthMethods": [ "ConnectionString" ],
    "postgresConnectionString": "",
    "Server": "",
    "PostgresDatabase": "",
    "User": "",
    "Timeout": 30
  },
  "KeyVault": {
    "UseKeyVault": true
  },
  "ApiBaseRoute": "",
  "Frontend": {
    "Enabled": true
  },
  "Mqtt": {
    "Host": "localhost",
    "Port": 1883,
    "Username": "sara",
    "Topics": [
      "isar/+/inspection_result",
      "isar/+/inspection_value"
    ],
    "MaxRetryAttempts": 5,
    "ShouldFailOnMaxRetries": false,
    "AllowInsecureLocalConnections": false
  },
  "Analysis": {
    "Analyses": {
      "anonymize": { "Workflows": ["anonymizer"] },
      "fencilla": { "Workflows": ["anonymizer", "rain-drop", "fencilla"] },
      "cloe": { "Workflows": ["anonymizer", "rain-drop", "cloe"] },
      "thermal-reading": { "Workflows": ["anonymizer", "thermal-reading"] },
      "passthrough": { "Workflows": ["copy-raw-to-visualized"] }
    },
    "Workflows": {
      "anonymizer": {
        "OutputStorageAccount": "saradevstoreanon",
        "OutputFileExtension": ".jpg",
        "ArgoWorkflowTemplateName": "anonymizer-workflow-templates",
        "ArgoRunTemplateName": "run-anonymizer",
        "Outputs": {
          "preProcessed": {
            "Derivation": "PrimaryInputWithExtension",
            "FileExtension": ".tiff",
            "ExtrasKey": "preProcessedBlobStorageLocation"
          }
        }
      },
      "rain-drop": {
        "OutputStorageAccount": "saradevstorevis",
        "OutputFileExtension": ".json",
        "IsGate": true,
        "SkipChainIf": { "ResultJsonKeyToCheckForSkipBoolean": "rain", "Value": "true" },
        "ArgoWorkflowTemplateName": "rain-drop-detector-workflow-templates",
        "ArgoRunTemplateName": "run-rain-drop-detector"
      },
      "fencilla": {
        "OutputStorageAccount": "saradevstorevis",
        "ArgoWorkflowTemplateName": "fencilla-workflow-templates",
        "ArgoRunTemplateName": "run-fencilla"
      },
      "cloe": {
        "OutputStorageAccount": "saradevstorevis",
        "ArgoWorkflowTemplateName": "cloe-workflow-templates",
        "ArgoRunTemplateName": "run-constant-level-oiler-estimator"
      },
      "thermal-reading": {
        "OutputStorageAccount": "saradevstorevis",
        "ArgoWorkflowTemplateName": "thermal-reading-workflow-templates",
        "ArgoRunTemplateName": "run-thermal-reading",
        "InputSource": {
          "FromPriorWorkflowType": "anonymizer",
          "OutputName": "preProcessed"
        }
      },
      "copy-raw-to-visualized": {
        "OutputStorageAccount": "saradevstoreanon",
        "ArgoWorkflowTemplateName": "utilities-workflow-templates",
        "ArgoRunTemplateName": "run-utilities"
      }
    },
    "DefaultAnalysisByFileExtension": {
      ".jpg": ["anonymize"],
      ".jpeg": ["anonymize"],
      ".png": ["anonymize"]
    },
    "DefaultAnalysisByInspectionTypeAndExtension": {
      "ThermalVideo": { ".mp4": ["passthrough"] },
      "AcousticMeasurement": { ".mp4": ["passthrough"] }
    },
    "AnalysisGroupTimeoutMinutes": 30
  },
  "SARATimeseriesBaseUrl": "http://sara-timeseries:8200",
  "Storage": {
    "ThermalReferenceStorageAccount": ""
  },
  "Email": {
    "Fencilla": {
      "Installations": {}
    }
  }
}
