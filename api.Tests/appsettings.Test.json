{
  "AppName": "SaraBackendTest",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com",
    "TenantId": "00000000-0000-0000-0000-000000000000",
    "ClientId": "00000000-0000-0000-0000-000000000000",
    "Domain": "test.local"
  },
  "EndpointConfig": {
    "DefaultScheme": "http",
    "DefaultHost": "localhost",
    "DefaultPort": 8100
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [],
  "Database": {
    "UseInMemoryDatabase": false,
    "postgresConnectionString": ""
  },
  "KeyVault": {
    "UseKeyVault": false
  },
  "Frontend": {
    "Enabled": false
  },
  "SARATimeseriesBaseUrl": "",
  "OpenTelemetry": {
    "Enabled": false
  },
  "Analysis": {
    "AnalysisGroupTimeoutMinutes": 60,
    "AnalysisGroupTimeoutCheckIntervalSeconds": 60,
    "Analyses": {
      "per-record-test": {
        "Workflows": ["test-workflow-1"]
      },
      "multi-step-test": {
        "Workflows": ["test-workflow-1", "test-workflow-2"]
      },
      "multi-step-gated-test": {
        "Workflows": ["test-workflow-1", "test-gate", "test-workflow-2"]
      },
      "group-test": {
        "Workflows": ["test-workflow-1"]
      },
      "thermal-reading": {
        "Workflows": ["thermal-reading"]
      }
    },
    "Workflows": {
      "test-workflow-1": {
        "TriggerUrl": "http://argo.invalid/api/v1/workflows/test-1",
        "OutputStorageAccount": "outstorage",
        "OutputBlobContainer": "out-container",
        "OutputFileExtension": ".json"
      },
      "test-workflow-2": {
        "TriggerUrl": "http://argo.invalid/api/v1/workflows/test-2",
        "OutputStorageAccount": "outstorage",
        "OutputBlobContainer": "out-container",
        "OutputFileExtension": ".json"
      },
      "thermal-reading": {
        "TriggerUrl": "http://argo.invalid/api/v1/workflows/thermal-reading",
        "OutputStorageAccount": "outstorage",
        "OutputBlobContainer": "out-container",
        "OutputFileExtension": ".json"
      },
      "fencilla": {
        "TriggerUrl": "http://argo.invalid/api/v1/workflows/fencilla",
        "OutputStorageAccount": "outstorage",
        "OutputBlobContainer": "out-container",
        "OutputFileExtension": ".json"
      },
      "test-gate": {
        "TriggerUrl": "http://argo.invalid/api/v1/workflows/test-gate",
        "OutputStorageAccount": "outstorage",
        "OutputBlobContainer": "out-container",
        "OutputFileExtension": ".json",
        "IsGate": true,
        "SkipChainIf": {
          "ResultJsonKeyToCheckForSkipBoolean": "skip",
          "Value": "true"
        }
      }
    },
    "DefaultAnalysisByFileExtension": {
      ".jpg": ["per-record-test"],
      ".mp4": ["per-record-test"]
    },
    "DefaultAnalysisByInspectionTypeAndExtension": {
      "TestVideo": { ".mp4": ["multi-step-test"] }
    }
  }
}
