SARA_SERVER_URL="http://localhost:8100"
TENANT_ID=
NOTIFIER_CLIENT_ID=
# Optional: only required when "ClientSecret" is in ALLOWED_AUTH_METHODS.
NOTIFIER_CLIENT_SECRET=
SARA_APP_REG_SCOPE=

# Ordered, comma-separated list of credential types to try. Allowed values:
# "WorkloadIdentity", "ClientSecret". Order determines priority inside the
# resulting ChainedTokenCredential when more than one is configured.
ALLOWED_AUTH_METHODS=WorkloadIdentity,ClientSecret
